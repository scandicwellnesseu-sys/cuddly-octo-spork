{% comment %}
  Footer section for Supplements Strong Theme
{% endcomment %}

<footer class="site-footer">
  <div class="container">
    
    <!-- Main Footer Content -->
    <div class="footer-main">
      <div class="row">
        
        <!-- Company Info -->
        <div class="col-3">
          <div class="footer-section">
            <div class="footer-logo">
              {% if settings.logo %}
                <img 
                  src="{{ settings.logo | img_url: '150x150' }}" 
                  alt="{{ shop.name }}"
                  class="footer-logo-image"
                >
              {% else %}
                <h3 class="footer-logo-text">{{ shop.name }}</h3>
              {% endif %}
            </div>
            
            {% if section.settings.footer_description != blank %}
              <p class="footer-description">{{ section.settings.footer_description }}</p>
            {% endif %}
            
            <!-- Trust Badges -->
            <div class="footer-trust">
              <div class="trust-badge-small">
                <span>🧬</span>
                <span>Lab Tested</span>
              </div>
              <div class="trust-badge-small">
                <span>🌿</span>
                <span>Natural</span>
              </div>
              <div class="trust-badge-small">
                <span>🚚</span>
                <span>Free Shipping</span>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Quick Links -->
        <div class="col-3">
          <div class="footer-section">
            <h4 class="footer-title">Quick Links</h4>
            <ul class="footer-links">
              {% for link in linklists[section.settings.footer_menu_1].links %}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
              {% endfor %}
            </ul>
          </div>
        </div>
        
        <!-- Customer Service -->
        <div class="col-3">
          <div class="footer-section">
            <h4 class="footer-title">Customer Service</h4>
            <ul class="footer-links">
              {% for link in linklists[section.settings.footer_menu_2].links %}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
              {% endfor %}
            </ul>
          </div>
        </div>
        
        <!-- Newsletter & Contact -->
        <div class="col-3">
          <div class="footer-section">
            <h4 class="footer-title">Stay Connected</h4>
            
            <!-- Newsletter Signup -->
            {% if section.settings.show_newsletter %}
              <div class="newsletter-signup">
                <p>Get the latest on supplements and wellness</p>
                <form action="{{ routes.customer_url }}" method="post" class="newsletter-form">
                  <input type="hidden" name="form_type" value="customer">
                  <input type="hidden" name="utf8" value="✓">
                  <div class="newsletter-input-wrapper">
                    <input 
                      type="email" 
                      name="contact[email]" 
                      placeholder="Enter your email"
                      class="newsletter-input"
                      required
                    >
                    <button type="submit" class="newsletter-submit">
                      Subscribe
                    </button>
                  </div>
                </form>
              </div>
            {% endif %}
            
            <!-- Contact Info -->
            {% if section.settings.show_contact_info %}
              <div class="contact-info">
                {% if section.settings.contact_phone != blank %}
                  <div class="contact-item">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
                    </svg>
                    <a href="tel:{{ section.settings.contact_phone }}">{{ section.settings.contact_phone }}</a>
                  </div>
                {% endif %}
                
                {% if section.settings.contact_email != blank %}
                  <div class="contact-item">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                      <polyline points="22,6 12,13 2,6"></polyline>
                    </svg>
                    <a href="mailto:{{ section.settings.contact_email }}">{{ section.settings.contact_email }}</a>
                  </div>
                {% endif %}
              </div>
            {% endif %}
            
            <!-- Social Media -->
            {% if section.settings.show_social %}
              <div class="social-links">
                {% if section.settings.social_facebook != blank %}
                  <a href="{{ section.settings.social_facebook }}" target="_blank" aria-label="Facebook">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                    </svg>
                  </a>
                {% endif %}
                
                {% if section.settings.social_instagram != blank %}
                  <a href="{{ section.settings.social_instagram }}" target="_blank" aria-label="Instagram">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                    </svg>
                  </a>
                {% endif %}
                
                {% if section.settings.social_twitter != blank %}
                  <a href="{{ section.settings.social_twitter }}" target="_blank" aria-label="Twitter">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
                    </svg>
                  </a>
                {% endif %}
              </div>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
    
    <!-- Footer Bottom -->
    <div class="footer-bottom">
      <div class="row align-items-center">
        <div class="col-6">
          <p class="copyright">
            &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.
          </p>
        </div>
        
        <div class="col-6 text-right">
          <!-- Payment Icons -->
          {% if section.settings.show_payment_icons %}
            <div class="payment-icons">
              <span class="payment-text">We accept:</span>
              {% for type in shop.enabled_payment_types %}
                {{ type | payment_type_img_tag }}
              {% endfor %}
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: #2c3e50;
    color: white;
    padding: 3rem 0 1rem;
    margin-top: 4rem;
  }
  
  .footer-main {
    margin-bottom: 2rem;
  }
  
  .footer-section {
    padding-right: 2rem;
  }
  
  .footer-logo-image {
    max-height: 60px;
    width: auto;
    margin-bottom: 1rem;
  }
  
  .footer-logo-text {
    color: white;
    margin-bottom: 1rem;
    font-size: 1.5rem;
  }
  
  .footer-description {
    color: #bdc3c7;
    line-height: 1.5;
    margin-bottom: 1.5rem;
  }
  
  .footer-trust {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  
  .trust-badge-small {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.75rem;
    background: rgba(255,255,255,0.1);
    padding: 0.25rem 0.5rem;
    border-radius: 0.25rem;
  }
  
  .footer-title {
    color: white;
    margin-bottom: 1rem;
    font-size: 1.125rem;
    font-weight: 600;
  }
  
  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  
  .footer-links li {
    margin-bottom: 0.5rem;
  }
  
  .footer-links a {
    color: #bdc3c7;
    text-decoration: none;
    transition: color 0.3s ease;
  }
  
  .footer-links a:hover {
    color: white;
  }
  
  .newsletter-signup {
    margin-bottom: 1.5rem;
  }
  
  .newsletter-signup p {
    color: #bdc3c7;
    margin-bottom: 1rem;
    font-size: 0.875rem;
  }
  
  .newsletter-input-wrapper {
    display: flex;
    border: 1px solid #34495e;
    border-radius: 0.25rem;
    overflow: hidden;
  }
  
  .newsletter-input {
    flex: 1;
    border: none;
    padding: 0.75rem;
    background: #34495e;
    color: white;
    outline: none;
  }
  
  .newsletter-input::placeholder {
    color: #95a5a6;
  }
  
  .newsletter-submit {
    background: var(--color-primary);
    color: white;
    border: none;
    padding: 0.75rem 1rem;
    cursor: pointer;
    font-weight: 600;
    transition: background-color 0.3s ease;
  }
  
  .newsletter-submit:hover {
    background: var(--color-secondary);
  }
  
  .contact-info {
    margin-bottom: 1.5rem;
  }
  
  .contact-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }
  
  .contact-item a {
    color: #bdc3c7;
    text-decoration: none;
  }
  
  .contact-item a:hover {
    color: white;
  }
  
  .social-links {
    display: flex;
    gap: 1rem;
  }
  
  .social-links a {
    color: #bdc3c7;
    transition: color 0.3s ease;
  }
  
  .social-links a:hover {
    color: white;
  }
  
  .footer-bottom {
    border-top: 1px solid #34495e;
    padding-top: 1rem;
  }
  
  .copyright {
    color: #95a5a6;
    margin: 0;
    font-size: 0.875rem;
  }
  
  .payment-icons {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  
  .payment-text {
    color: #95a5a6;
    font-size: 0.875rem;
  }
  
  .payment-icons img {
    height: 24px;
    width: auto;
  }
  
  @media (max-width: 768px) {
    .footer-section {
      padding-right: 0;
      margin-bottom: 2rem;
    }
    
    .footer-main .col-3 {
      flex: 0 0 100%;
      max-width: 100%;
    }
    
    .footer-bottom .col-6 {
      flex: 0 0 100%;
      max-width: 100%;
      text-align: center !important;
      margin-bottom: 1rem;
    }
    
    .footer-trust {
      justify-content: center;
    }
    
    .social-links {
      justify-content: center;
    }
    
    .payment-icons {
      justify-content: center;
    }
  }
</style>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "header",
      "content": "Company Information"
    },
    {
      "type": "textarea",
      "id": "footer_description",
      "label": "Footer description",
      "default": "Your trusted source for premium supplements and wellness products."
    },
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "link_list",
      "id": "footer_menu_1",
      "label": "First footer menu",
      "default": "footer"
    },
    {
      "type": "link_list",
      "id": "footer_menu_2",
      "label": "Second footer menu"
    },
    {
      "type": "header",
      "content": "Newsletter"
    },
    {
      "type": "checkbox",
      "id": "show_newsletter",
      "label": "Show newsletter signup",
      "default": true
    },
    {
      "type": "header",
      "content": "Contact Information"
    },
    {
      "type": "checkbox",
      "id": "show_contact_info",
      "label": "Show contact information",
      "default": true
    },
    {
      "type": "text",
      "id": "contact_phone",
      "label": "Phone number"
    },
    {
      "type": "text",
      "id": "contact_email",
      "label": "Email address"
    },
    {
      "type": "header",
      "content": "Social Media"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Show social media links",
      "default": true
    },
    {
      "type": "url",
      "id": "social_facebook",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "social_instagram",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "social_twitter",
      "label": "Twitter URL"
    },
    {
      "type": "header",
      "content": "Payment"
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Show payment icons",
      "default": true
    }
  ]
}
{% endschema %}