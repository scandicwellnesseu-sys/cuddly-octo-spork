{% comment %}
  Hero section for homepage
{% endcomment %}

<section class="hero" role="region" aria-label="{{ 'sections.hero.label' | t }}">
  <div class="hero__container">
    <div class="hero__content">
      <h1 class="hero__title">{{ section.settings.hero_title | escape }}</h1>
      <p class="hero__subtitle">{{ section.settings.hero_subtitle | escape }}</p>
      
      {%- if section.settings.hero_button_text != blank -%}
        <a href="{{ section.settings.hero_button_link }}" class="hero__button">
          {{ section.settings.hero_button_text | escape }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "text",
      "id": "hero_title",
      "label": "Hero title",
      "default": "ScandicWellness"
    },
    {
      "type": "textarea",
      "id": "hero_subtitle",
      "label": "Hero subtitle",
      "default": "Din digitala coach för vitaminer och kosttillskott"
    },
    {
      "type": "text",
      "id": "hero_button_text",
      "label": "Button text",
      "default": "Utforska produkter"
    },
    {
      "type": "url",
      "id": "hero_button_link",
      "label": "Button link",
      "default": "/collections/all"
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}
