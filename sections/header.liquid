{% comment %}
  Header section for Supplements Strong Theme
{% endcomment %}

<header class="site-header" data-header>
  <div class="container">
    <div class="header-content">
      
      <!-- Mobile menu toggle -->
      <button 
        class="mobile-menu-toggle"
        data-mobile-menu-toggle
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Toggle mobile menu"
      >
        <span class="hamburger"></span>
        <span class="hamburger"></span>
        <span class="hamburger"></span>
      </button>
      
      <!-- Logo -->
      <div class="site-logo">
        <a href="/" class="logo-link">
          {% if settings.logo %}
            <img 
              src="{{ settings.logo | img_url: '200x200' }}" 
              alt="{{ shop.name }}"
              class="logo-image"
              width="150"
              height="auto"
            >
          {% else %}
            <span class="logo-text">{{ shop.name }}</span>
          {% endif %}
        </a>
      </div>
      
      <!-- Main Navigation -->
      <nav class="main-navigation" role="navigation">
        <ul class="nav-list">
          {% for link in linklists.main-menu.links %}
            <li class="nav-item {% if link.links.size > 0 %}has-dropdown{% endif %}">
              <a href="{{ link.url }}" class="nav-link">
                {{ link.title }}
                {% if link.links.size > 0 %}
                  <span class="dropdown-arrow">▼</span>
                {% endif %}
              </a>
              
              {% if link.links.size > 0 %}
                <ul class="dropdown-menu">
                  {% for child_link in link.links %}
                    <li class="dropdown-item">
                      <a href="{{ child_link.url }}" class="dropdown-link">
                        {{ child_link.title }}
                      </a>
                    </li>
                  {% endfor %}
                </ul>
              {% endif %}
            </li>
          {% endfor %}
        </ul>
      </nav>
      
      <!-- Header Actions -->
      <div class="header-actions">
        
        <!-- Search -->
        <div class="search-wrapper">
          <button class="search-toggle" aria-label="Open search">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="11" cy="11" r="8"></circle>
              <path d="m21 21-4.35-4.35"></path>
            </svg>
          </button>
          
          <div class="search-dropdown" hidden>
            <form action="{{ routes.search_url }}" method="get" class="search-form">
              <input 
                type="search" 
                name="q" 
                placeholder="Search products..."
                class="search-input"
                data-search-input
                autocomplete="off"
              >
              <button type="submit" class="search-submit" aria-label="Search">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="11" cy="11" r="8"></circle>
                  <path d="m21 21-4.35-4.35"></path>
                </svg>
              </button>
            </form>
            
            <div class="search-results" data-search-results hidden>
              <!-- Search results populated by JavaScript -->
            </div>
          </div>
        </div>
        
        <!-- Account -->
        <div class="account-wrapper">
          <a href="/account" class="account-link" aria-label="Account">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
              <circle cx="12" cy="7" r="4"></circle>
            </svg>
          </a>
        </div>
        
        <!-- Cart -->
        <div class="cart-wrapper">
          <a href="/cart" class="cart-link" aria-label="Cart">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M9 22C9.55228 22 10 21.5523 10 21C10 20.4477 9.55228 20 9 20C8.44772 20 8 20.4477 8 21C8 21.5523 8.44772 22 9 22Z"></path>
              <path d="M20 22C20.5523 22 21 21.5523 21 21C21 20.4477 20.5523 20 20 20C19.4477 20 19 20.4477 19 21C19 21.5523 19.4477 22 20 22Z"></path>
              <path d="M1 1H5L7.68 14.39C7.77144 14.8504 8.02191 15.264 8.38755 15.5583C8.75318 15.8526 9.2107 16.009 9.68 16H19.4C19.8693 16.009 20.3268 15.8526 20.6925 15.5583C21.0581 15.264 21.3086 14.8504 21.4 14.39L23 6H6"></path>
            </svg>
            <span class="cart-count" data-cart-count>{{ cart.item_count }}</span>
          </a>
        </div>
      </div>
    </div>
  </div>
  
  <!-- Mobile Menu -->
  <div class="mobile-menu" id="mobile-menu" data-mobile-menu hidden>
    <nav class="mobile-navigation">
      <ul class="mobile-nav-list">
        {% for link in linklists.main-menu.links %}
          <li class="mobile-nav-item">
            <a href="{{ link.url }}" class="mobile-nav-link">
              {{ link.title }}
            </a>
            
            {% if link.links.size > 0 %}
              <ul class="mobile-submenu">
                {% for child_link in link.links %}
                  <li class="mobile-submenu-item">
                    <a href="{{ child_link.url }}" class="mobile-submenu-link">
                      {{ child_link.title }}
                    </a>
                  </li>
                {% endfor %}
              </ul>
            {% endif %}
          </li>
        {% endfor %}
        
        <!-- Mobile account/search links -->
        <li class="mobile-nav-item mobile-divider">
          <a href="/account" class="mobile-nav-link">My Account</a>
        </li>
        <li class="mobile-nav-item">
          <a href="/search" class="mobile-nav-link">Search</a>
        </li>
      </ul>
    </nav>
  </div>
</header>

{% if settings.enable_sticky_header %}
  <div class="header-spacer"></div>
{% endif %}

<style>
  .site-header {
    background: white;
    border-bottom: 1px solid #eee;
    {% if settings.enable_sticky_header %}
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      transition: transform 0.3s ease;
    {% endif %}
  }
  
  {% if settings.enable_sticky_header %}
    .header-spacer {
      height: 80px;
    }
    
    .header-hidden {
      transform: translateY(-100%);
    }
  {% endif %}
  
  .header-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 0;
    min-height: 80px;
  }
  
  .mobile-menu-toggle {
    display: none;
    background: none;
    border: none;
    flex-direction: column;
    cursor: pointer;
    padding: 0.5rem;
  }
  
  .hamburger {
    width: 20px;
    height: 2px;
    background: var(--color-text);
    margin: 2px 0;
    transition: 0.3s;
  }
  
  .logo-link {
    display: inline-block;
  }
  
  .logo-image {
    max-height: 50px;
    width: auto;
  }
  
  .logo-text {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-primary);
    text-decoration: none;
  }
  
  .main-navigation {
    flex: 1;
    margin: 0 2rem;
  }
  
  .nav-list {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
    justify-content: center;
    gap: 2rem;
  }
  
  .nav-item {
    position: relative;
  }
  
  .nav-link {
    color: var(--color-text);
    text-decoration: none;
    font-weight: 500;
    padding: 0.5rem 0;
    display: flex;
    align-items: center;
    gap: 0.25rem;
    transition: color 0.3s ease;
  }
  
  .nav-link:hover {
    color: var(--color-primary);
  }
  
  .dropdown-arrow {
    font-size: 0.75rem;
    transition: transform 0.3s ease;
  }
  
  .nav-item:hover .dropdown-arrow {
    transform: rotate(180deg);
  }
  
  .dropdown-menu {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    background: white;
    border: 1px solid #eee;
    border-radius: 0.375rem;
    box-shadow: 0 4px 8px rgba(0,0,0,0.1);
    list-style: none;
    margin: 0;
    padding: 0.5rem 0;
    min-width: 200px;
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s ease;
    z-index: 10;
  }
  
  .nav-item:hover .dropdown-menu {
    opacity: 1;
    visibility: visible;
  }
  
  .dropdown-link {
    display: block;
    padding: 0.5rem 1rem;
    color: var(--color-text);
    text-decoration: none;
    transition: background-color 0.3s ease;
  }
  
  .dropdown-link:hover {
    background-color: #f8f9fa;
    color: var(--color-primary);
  }
  
  .header-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  
  .search-wrapper {
    position: relative;
  }
  
  .search-toggle,
  .account-link,
  .cart-link {
    background: none;
    border: none;
    color: var(--color-text);
    cursor: pointer;
    padding: 0.5rem;
    border-radius: 0.25rem;
    transition: background-color 0.3s ease;
    text-decoration: none;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .search-toggle:hover,
  .account-link:hover,
  .cart-link:hover {
    background-color: #f8f9fa;
  }
  
  .cart-link {
    position: relative;
  }
  
  .cart-count {
    position: absolute;
    top: -8px;
    right: -8px;
    background: var(--color-accent);
    color: white;
    border-radius: 50%;
    font-size: 0.75rem;
    font-weight: 600;
    min-width: 18px;
    height: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }
  
  .search-dropdown {
    position: absolute;
    top: 100%;
    right: 0;
    background: white;
    border: 1px solid #eee;
    border-radius: 0.375rem;
    box-shadow: 0 4px 8px rgba(0,0,0,0.1);
    padding: 1rem;
    min-width: 300px;
    z-index: 10;
  }
  
  .search-form {
    display: flex;
    border: 1px solid #ddd;
    border-radius: 0.25rem;
    overflow: hidden;
  }
  
  .search-input {
    flex: 1;
    border: none;
    padding: 0.5rem;
    outline: none;
  }
  
  .search-submit {
    background: var(--color-primary);
    color: white;
    border: none;
    padding: 0.5rem;
    cursor: pointer;
  }
  
  .search-results {
    margin-top: 1rem;
    max-height: 300px;
    overflow-y: auto;
  }
  
  .search-result {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.5rem;
    border-radius: 0.25rem;
    transition: background-color 0.3s ease;
  }
  
  .search-result:hover {
    background-color: #f8f9fa;
  }
  
  .search-result img {
    width: 50px;
    height: 50px;
    object-fit: cover;
    border-radius: 0.25rem;
  }
  
  .search-result h4 {
    margin: 0;
    font-size: 0.875rem;
  }
  
  .search-result .price {
    color: var(--color-primary);
    font-weight: 600;
  }
  
  .mobile-menu {
    background: white;
    border-top: 1px solid #eee;
  }
  
  .mobile-nav-list {
    list-style: none;
    margin: 0;
    padding: 1rem 0;
  }
  
  .mobile-nav-link {
    display: block;
    padding: 0.75rem 1rem;
    color: var(--color-text);
    text-decoration: none;
    font-weight: 500;
  }
  
  .mobile-nav-link:hover {
    background-color: #f8f9fa;
    color: var(--color-primary);
  }
  
  .mobile-submenu {
    list-style: none;
    margin: 0;
    padding: 0;
    background-color: #f8f9fa;
  }
  
  .mobile-submenu-link {
    display: block;
    padding: 0.5rem 2rem;
    color: var(--color-text);
    text-decoration: none;
    font-size: 0.875rem;
  }
  
  .mobile-submenu-link:hover {
    color: var(--color-primary);
  }
  
  .mobile-divider {
    border-top: 1px solid #eee;
    margin-top: 1rem;
    padding-top: 1rem;
  }
  
  @media (max-width: 768px) {
    .mobile-menu-toggle {
      display: flex;
    }
    
    .main-navigation {
      display: none;
    }
    
    .header-actions {
      gap: 0.5rem;
    }
    
    .search-dropdown {
      right: -50px;
      min-width: 250px;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Search functionality
    const searchToggle = document.querySelector('.search-toggle');
    const searchDropdown = document.querySelector('.search-dropdown');
    
    if (searchToggle && searchDropdown) {
      searchToggle.addEventListener('click', function() {
        const isVisible = !searchDropdown.hidden;
        searchDropdown.hidden = isVisible;
        
        if (!isVisible) {
          searchDropdown.querySelector('.search-input').focus();
        }
      });
      
      // Close search dropdown when clicking outside
      document.addEventListener('click', function(e) {
        if (!searchToggle.contains(e.target) && !searchDropdown.contains(e.target)) {
          searchDropdown.hidden = true;
        }
      });
    }
  });
</script>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 50,
      "max": 300,
      "step": 10,
      "default": 150,
      "unit": "px",
      "label": "Logo width"
    },
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "link_list",
      "id": "main_menu",
      "label": "Main menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}