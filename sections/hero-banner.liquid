{% comment %}
  Hero banner section for homepage
{% endcomment %}

<section class="hero-banner" style="background-color: {{ section.settings.background_color }};">
  <div class="hero-content">
    
    {% if section.settings.background_image %}
      <div class="hero-image">
        <img 
          src="{{ section.settings.background_image | img_url: '1920x800' }}" 
          alt="{{ section.settings.background_image.alt | default: section.settings.heading }}"
          class="hero-bg-image"
        >
        <div class="hero-overlay" style="background-color: {{ section.settings.overlay_color }}; opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"></div>
      </div>
    {% endif %}
    
    <div class="container">
      <div class="hero-text">
        {% if section.settings.heading != blank %}
          <h1 class="hero-heading" style="color: {{ section.settings.text_color }};">
            {{ section.settings.heading }}
          </h1>
        {% endif %}
        
        {% if section.settings.subheading != blank %}
          <p class="hero-subheading" style="color: {{ section.settings.text_color }};">
            {{ section.settings.subheading }}
          </p>
        {% endif %}
        
        <div class="hero-buttons">
          {% if section.settings.button_text != blank and section.settings.button_link != blank %}
            <a href="{{ section.settings.button_link }}" class="btn btn-primary btn-large hero-btn-primary">
              {{ section.settings.button_text }}
            </a>
          {% endif %}
          
          {% if section.settings.button_text_2 != blank and section.settings.button_link_2 != blank %}
            <a href="{{ section.settings.button_link_2 }}" class="btn btn-secondary btn-large hero-btn-secondary">
              {{ section.settings.button_text_2 }}
            </a>
          {% endif %}
        </div>
        
        {% if section.settings.show_trust_badges %}
          <div class="hero-trust-badges">
            <div class="trust-badge">
              <span>🧬</span>
              <span>Lab Tested</span>
            </div>
            <div class="trust-badge">
              <span>🌿</span>
              <span>100% Natural</span>
            </div>
            <div class="trust-badge">
              <span>🚚</span>
              <span>Free Shipping</span>
            </div>
            <div class="trust-badge">
              <span>💯</span>
              <span>Money Back Guarantee</span>
            </div>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

<style>
  .hero-banner {
    position: relative;
    padding: 4rem 0;
    min-height: 500px;
    display: flex;
    align-items: center;
    overflow: hidden;
  }
  
  .hero-content {
    position: relative;
    width: 100%;
    z-index: 2;
  }
  
  .hero-image {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 1;
  }
  
  .hero-bg-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
  }
  
  .hero-text {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }
  
  .hero-heading {
    font-size: 3rem;
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 1rem;
  }
  
  .hero-subheading {
    font-size: 1.25rem;
    line-height: 1.5;
    margin-bottom: 2rem;
    opacity: 0.9;
  }
  
  .hero-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }
  
  .hero-btn-primary {
    background-color: {{ section.settings.button_color | default: 'var(--color-primary)' }};
    border-color: {{ section.settings.button_color | default: 'var(--color-primary)' }};
  }
  
  .hero-btn-primary:hover {
    background-color: {{ section.settings.button_hover_color | default: 'var(--color-secondary)' }};
    border-color: {{ section.settings.button_hover_color | default: 'var(--color-secondary)' }};
  }
  
  .hero-trust-badges {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 2rem;
  }
  
  .hero-trust-badges .trust-badge {
    background: rgba(255,255,255,0.1);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 0.5rem;
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  
  @media (max-width: 768px) {
    .hero-banner {
      padding: 3rem 0;
      min-height: 400px;
    }
    
    .hero-heading {
      font-size: 2rem;
    }
    
    .hero-subheading {
      font-size: 1.125rem;
    }
    
    .hero-buttons {
      flex-direction: column;
      align-items: center;
    }
    
    .hero-buttons .btn {
      width: 100%;
      max-width: 300px;
    }
    
    .hero-trust-badges {
      gap: 0.5rem;
    }
    
    .hero-trust-badges .trust-badge {
      padding: 0.375rem 0.75rem;
      font-size: 0.75rem;
    }
  }
  
  @media (max-width: 480px) {
    .hero-heading {
      font-size: 1.75rem;
    }
    
    .hero-trust-badges {
      flex-direction: column;
      align-items: center;
    }
  }
</style>

{% schema %}
{
  "name": "Hero banner",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Premium Supplements for Optimal Health"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Discover our scientifically-backed supplements designed to support your wellness journey."
    },
    {
      "type": "header",
      "content": "Buttons"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "First button text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "First button link"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "First button color",
      "default": "#2E7D32"
    },
    {
      "type": "color",
      "id": "button_hover_color",
      "label": "First button hover color",
      "default": "#4CAF50"
    },
    {
      "type": "text",
      "id": "button_text_2",
      "label": "Second button text",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "button_link_2",
      "label": "Second button link"
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#f8f9fa"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Image overlay color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Image overlay opacity",
      "min": 0,
      "max": 80,
      "step": 10,
      "default": 40,
      "unit": "%"
    },
    {
      "type": "header",
      "content": "Trust badges"
    },
    {
      "type": "checkbox",
      "id": "show_trust_badges",
      "label": "Show trust badges",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Hero banner"
    }
  ]
}
{% endschema %}