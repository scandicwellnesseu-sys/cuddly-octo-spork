# ===========================================
# AI Product Description Generator PRO
# Miljövariabler
# ===========================================

# Database (PostgreSQL - Supabase / Neon)
DATABASE_URL="postgresql://user:password@localhost:5432/ai_product_pro?schema=public"

# NextAuth
NEXTAUTH_SECRET="your-secret-key-here-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# OpenAI
OPENAI_API_KEY="sk-your-openai-api-key"
OPENAI_ORGANIZATION="org-your-org-id"

# Claude (Anthropic) - Fallback
ANTHROPIC_API_KEY="sk-ant-your-anthropic-key"

# Google Cloud Vision API (OCR)
GOOGLE_CLOUD_PROJECT_ID="your-project-id"
GOOGLE_CLOUD_PRIVATE_KEY="your-private-key"
GOOGLE_CLOUD_CLIENT_EMAIL="your-service-account@project.iam.gserviceaccount.com"

# Stripe
STRIPE_SECRET_KEY="sk_test_your-stripe-secret-key"
STRIPE_PUBLISHABLE_KEY="pk_test_your-stripe-publishable-key"
STRIPE_WEBHOOK_SECRET="whsec_your-webhook-secret"

# Stripe Price IDs
STRIPE_PRICE_STARTER="price_starter_free"
STRIPE_PRICE_PRO="price_pro_490"
STRIPE_PRICE_AGENCY="price_agency_2990"
STRIPE_PRICE_CREDITS_100="price_credits_100"
STRIPE_PRICE_CREDITS_500="price_credits_500"

# File Storage (Cloudflare R2 / AWS S3)
S3_ENDPOINT="https://your-account.r2.cloudflarestorage.com"
S3_ACCESS_KEY_ID="your-access-key"
S3_SECRET_ACCESS_KEY="your-secret-key"
S3_BUCKET_NAME="ai-product-pro-files"
S3_REGION="auto"

# Shopify Integration
SHOPIFY_API_KEY="your-shopify-api-key"
SHOPIFY_API_SECRET="your-shopify-secret"

# WooCommerce Integration
# (Per store - configured in database)

# Google Trends / SEMrush API
SEMRUSH_API_KEY="your-semrush-api-key"
GOOGLE_TRENDS_API_KEY="your-google-trends-key"

# Social Media Trends
TIKTOK_API_KEY="your-tiktok-api-key"
INSTAGRAM_API_KEY="your-instagram-api-key"

# Email (Resend / Postmark)
RESEND_API_KEY="re_your-resend-api-key"
EMAIL_FROM="noreply@aiproductpro.se"

# Logging & Monitoring
LOGTAIL_TOKEN="your-logtail-token"
SENTRY_DSN="https://your-sentry-dsn"

# App Configuration
NODE_ENV="development"
PORT=4000
FRONTEND_URL="http://localhost:3000"
BACKEND_URL="http://localhost:4000"

# Credits Configuration
CREDITS_PER_GENERATION=1
CREDITS_PER_BULK_IMAGE=1
CREDITS_PER_TRANSLATION=1
