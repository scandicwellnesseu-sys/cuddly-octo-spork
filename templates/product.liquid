{% comment %}
  Product template for Supplements Strong Theme
{% endcomment %}

<div class="container">
  <div class="product-page">
    
    <!-- Breadcrumb -->
    <nav class="breadcrumb mt-3">
      <a href="/">Home</a>
      {% if collection %}
        <span> / </span>
        <a href="{{ collection.url }}">{{ collection.title }}</a>
      {% endif %}
      <span> / </span>
      <span>{{ product.title }}</span>
    </nav>

    <div class="row mt-4">
      <!-- Product Images -->
      <div class="col-6">
        <div class="product-images">
          {% if product.images.size > 0 %}
            <div class="main-image mb-3">
              <img 
                src="{{ product.featured_image | img_url: '800x800' }}" 
                alt="{{ product.featured_image.alt | default: product.title }}"
                data-main-image
                class="img-fluid"
              >
            </div>
            
            {% if product.images.size > 1 %}
              <div class="thumbnail-images">
                <div class="row">
                  {% for image in product.images limit: 4 %}
                    <div class="col-3">
                      <img 
                        src="{{ image | img_url: '200x200' }}" 
                        alt="{{ image.alt | default: product.title }}"
                        class="img-fluid thumbnail-image"
                        data-image-src="{{ image | img_url: '800x800' }}"
                      >
                    </div>
                  {% endfor %}
                </div>
              </div>
            {% endif %}
          {% else %}
            <div class="no-image">
              <img src="{{ 'product-placeholder.svg' | asset_url }}" alt="No image available" class="img-fluid">
            </div>
          {% endif %}
        </div>
      </div>

      <!-- Product Information -->
      <div class="col-6">
        <div class="product-info">
          
          <!-- Product badges -->
          {% if product.tags contains 'new' %}
            <span class="product-badge badge-new">New</span>
          {% endif %}
          {% if product.tags contains 'bestseller' %}
            <span class="product-badge badge-bestseller">Bestseller</span>
          {% endif %}
          {% if product.compare_at_price > product.price %}
            <span class="product-badge badge-sale">Sale</span>
          {% endif %}

          <h1 class="product-title">{{ product.title }}</h1>
          
          {% if settings.show_vendor and product.vendor != blank %}
            <p class="product-vendor">{{ product.vendor }}</p>
          {% endif %}

          <!-- Price -->
          <div class="product-price-wrapper mb-3">
            {% if product.compare_at_price > product.price %}
              <span class="price-compare" data-compare-price>{{ product.compare_at_price | money }}</span>
            {% endif %}
            <span class="product-price price-sale" data-price>{{ product.price | money }}</span>
          </div>

          <!-- Product Description -->
          {% if product.description != blank %}
            <div class="product-description mb-4">
              {{ product.description }}
            </div>
          {% endif %}

          <!-- Product Form -->
          <form action="/cart/add" method="post" enctype="multipart/form-data" data-product-form>
            
            <!-- Variants -->
            {% unless product.has_only_default_variant %}
              {% for option in product.options_with_values %}
                <div class="product-option mb-3">
                  <label for="Option{{ option.position }}">{{ option.name }}:</label>
                  <select 
                    name="id" 
                    id="Option{{ option.position }}"
                    data-variant-select
                    class="form-control"
                  >
                    {% for variant in product.variants %}
                      {% if variant.available %}
                        <option value="{{ variant.id }}">
                          {{ variant.title }} - {{ variant.price | money }}
                        </option>
                      {% endif %}
                    {% endfor %}
                  </select>
                </div>
              {% endfor %}
            {% else %}
              <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
            {% endunless %}

            <!-- Quantity -->
            <div class="quantity-wrapper mb-3">
              <label for="Quantity">Quantity:</label>
              <div class="quantity-input">
                <button type="button" class="quantity-btn" data-quantity-minus>-</button>
                <input 
                  type="number" 
                  id="Quantity" 
                  name="quantity" 
                  value="1" 
                  min="1"
                  class="quantity-input-field"
                >
                <button type="button" class="quantity-btn" data-quantity-plus>+</button>
              </div>
            </div>

            <!-- Add to Cart Button -->
            <button 
              type="submit" 
              class="btn btn-primary btn-large"
              data-add-to-cart
              {% unless product.available %}disabled{% endunless %}
            >
              <span class="btn-text">
                {% if product.available %}
                  Add to Cart
                {% else %}
                  Sold Out
                {% endif %}
              </span>
            </button>

            <!-- Availability -->
            <p class="availability mt-2" data-availability-text>
              {% if product.available %}
                In stock
              {% else %}
                Out of stock
              {% endif %}
            </p>

            <!-- Product JSON for JS -->
            <script type="application/json" data-product-json>
              {{ product | json }}
            </script>
          </form>

          <!-- Product Details -->
          {% if product.metafields.custom.supplement_facts %}
            <div class="supplement-facts mt-4">
              <h4>Supplement Facts</h4>
              {{ product.metafields.custom.supplement_facts }}
            </div>
          {% endif %}

          <!-- SKU -->
          {% if settings.show_sku and product.selected_or_first_available_variant.sku != blank %}
            <p class="product-sku mt-3">
              <strong>SKU:</strong> {{ product.selected_or_first_available_variant.sku }}
            </p>
          {% endif %}

          <!-- Share buttons -->
          <div class="product-share mt-4">
            <h5>Share this product:</h5>
            <div class="share-buttons">
              <a href="https://www.facebook.com/sharer/sharer.php?u={{ shop.secure_url }}{{ product.url }}" target="_blank" class="btn btn-secondary btn-sm">
                Facebook
              </a>
              <a href="https://twitter.com/intent/tweet?url={{ shop.secure_url }}{{ product.url }}&text={{ product.title }}" target="_blank" class="btn btn-secondary btn-sm">
                Twitter
              </a>
              <a href="mailto:?subject={{ product.title }}&body=Check out this product: {{ shop.secure_url }}{{ product.url }}" class="btn btn-secondary btn-sm">
                Email
              </a>
            </div>
          </div>

        </div>
      </div>
    </div>

    <!-- Product Tabs -->
    <div class="product-tabs mt-5">
      <div class="tab-nav">
        <button class="tab-button active" data-tab="description">Description</button>
        <button class="tab-button" data-tab="ingredients">Ingredients</button>
        <button class="tab-button" data-tab="usage">Usage</button>
        {% if settings.enable_product_reviews %}
          <button class="tab-button" data-tab="reviews">Reviews</button>
        {% endif %}
      </div>
      
      <div class="tab-content">
        <div class="tab-pane active" data-tab-content="description">
          {{ product.description }}
        </div>
        
        <div class="tab-pane" data-tab-content="ingredients">
          {% if product.metafields.custom.ingredients %}
            {{ product.metafields.custom.ingredients }}
          {% else %}
            <p>Ingredient information coming soon.</p>
          {% endif %}
        </div>
        
        <div class="tab-pane" data-tab-content="usage">
          {% if product.metafields.custom.usage_instructions %}
            {{ product.metafields.custom.usage_instructions }}
          {% else %}
            <p>Please follow the directions on the product label.</p>
          {% endif %}
        </div>
        
        {% if settings.enable_product_reviews %}
          <div class="tab-pane" data-tab-content="reviews">
            <div id="product-reviews">
              <!-- Reviews will be loaded here -->
              <p>Customer reviews coming soon.</p>
            </div>
          </div>
        {% endif %}
      </div>
    </div>

    <!-- Related Products -->
    {% if collections[product.type] and collections[product.type].products.size > 1 %}
      <section class="related-products mt-5">
        <h3>Related Products</h3>
        <div class="row">
          {% for related_product in collections[product.type].products limit: 4 %}
            {% unless related_product.id == product.id %}
              <div class="col-3">
                {% render 'product-card', product: related_product %}
              </div>
            {% endunless %}
          {% endfor %}
        </div>
      </section>
    {% endif %}

  </div>
</div>

<style>
  .breadcrumb a {
    color: var(--color-primary);
    text-decoration: none;
  }
  
  .breadcrumb a:hover {
    text-decoration: underline;
  }
  
  .thumbnail-image {
    cursor: pointer;
    border: 2px solid transparent;
    border-radius: 0.25rem;
    transition: border-color 0.3s ease;
  }
  
  .thumbnail-image:hover,
  .thumbnail-image.active {
    border-color: var(--color-primary);
  }
  
  .quantity-input {
    display: flex;
    align-items: center;
    border: 1px solid #ddd;
    border-radius: 0.25rem;
    width: fit-content;
  }
  
  .quantity-btn {
    background: none;
    border: none;
    padding: 0.5rem;
    cursor: pointer;
    font-size: 1.2rem;
    line-height: 1;
  }
  
  .quantity-input-field {
    border: none;
    text-align: center;
    width: 60px;
    padding: 0.5rem;
  }
  
  .product-tabs {
    border-top: 1px solid #eee;
    padding-top: 2rem;
  }
  
  .tab-nav {
    display: flex;
    border-bottom: 1px solid #eee;
    margin-bottom: 1rem;
  }
  
  .tab-button {
    background: none;
    border: none;
    padding: 1rem;
    cursor: pointer;
    border-bottom: 2px solid transparent;
    transition: border-color 0.3s ease;
  }
  
  .tab-button.active {
    border-bottom-color: var(--color-primary);
    color: var(--color-primary);
  }
  
  .tab-pane {
    display: none;
  }
  
  .tab-pane.active {
    display: block;
  }
  
  .share-buttons {
    display: flex;
    gap: 0.5rem;
  }
  
  .availability {
    font-weight: 600;
  }
  
  .availability-in-stock {
    color: var(--color-secondary);
  }
  
  .availability-out-of-stock {
    color: #dc3545;
  }
</style>

<script>
  // Product page functionality
  document.addEventListener('DOMContentLoaded', function() {
    // Thumbnail image switching
    const thumbnails = document.querySelectorAll('.thumbnail-image');
    const mainImage = document.querySelector('[data-main-image]');
    
    thumbnails.forEach(thumb => {
      thumb.addEventListener('click', function() {
        const newSrc = this.dataset.imageSrc;
        if (mainImage && newSrc) {
          mainImage.src = newSrc;
          
          // Update active thumbnail
          thumbnails.forEach(t => t.classList.remove('active'));
          this.classList.add('active');
        }
      });
    });
    
    // Quantity buttons
    const quantityMinus = document.querySelector('[data-quantity-minus]');
    const quantityPlus = document.querySelector('[data-quantity-plus]');
    const quantityInput = document.querySelector('.quantity-input-field');
    
    if (quantityMinus && quantityPlus && quantityInput) {
      quantityMinus.addEventListener('click', function() {
        const currentValue = parseInt(quantityInput.value);
        if (currentValue > 1) {
          quantityInput.value = currentValue - 1;
        }
      });
      
      quantityPlus.addEventListener('click', function() {
        const currentValue = parseInt(quantityInput.value);
        quantityInput.value = currentValue + 1;
      });
    }
    
    // Product tabs
    const tabButtons = document.querySelectorAll('.tab-button');
    const tabPanes = document.querySelectorAll('.tab-pane');
    
    tabButtons.forEach(button => {
      button.addEventListener('click', function() {
        const targetTab = this.dataset.tab;
        
        // Remove active class from all buttons and panes
        tabButtons.forEach(btn => btn.classList.remove('active'));
        tabPanes.forEach(pane => pane.classList.remove('active'));
        
        // Add active class to clicked button and corresponding pane
        this.classList.add('active');
        document.querySelector(`[data-tab-content="${targetTab}"]`).classList.add('active');
      });
    });
  });
</script>