    "theme_support_url": ""
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "header",
        "content": "Brand Colors"
      },
      {
        "type": "color",
        "id": "color_primary",
        "label": "Primary Color",
        "default": "#2E7D32"
      },
      {
        "type": "color",
        "id": "color_secondary",
        "label": "Secondary Color",
        "default": "#4CAF50"
      },
      {
        "type": "color",
        "id": "color_accent",
        "label": "Accent Color",
        "default": "#FF9800"
      },
      {
        "type": "color",
        "id": "color_text",
        "label": "Text Color",
        "default": "#333333"
      },
      {
        "type": "color",
        "id": "color_background",
        "label": "Background Color",
        "default": "#FFFFFF"
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "header",
        "content": "Font Settings"
      },
      {
        "type": "font_picker",
        "id": "font_heading",
        "label": "Heading Font",
        "default": "assistant_n4"
      },
      {
        "type": "font_picker",
        "id": "font_body",
        "label": "Body Font",
        "default": "assistant_n4"
      },
      {
        "type": "range",
        "id": "font_size_base",
        "label": "Base Font Size",
        "min": 14,
        "max": 18,
        "step": 1,
        "unit": "px",
        "default": 16
      }
    ]
  },
  {
    "name": "Layout",
    "settings": [
      {
        "type": "header",
        "content": "Page Layout"
      },
      {
        "type": "range",
        "id": "page_width",
        "label": "Page Width",
        "min": 1000,
        "max": 1400,
        "step": 50,
        "unit": "px",
        "default": 1200
      },
      {
        "type": "checkbox",
        "id": "enable_sticky_header",
        "label": "Enable Sticky Header",
        "default": true
      }
    ]
  },
  {
    "name": "Product",
    "settings": [
      {
        "type": "header",
        "content": "Product Settings"
      },
      {
        "type": "checkbox",
        "id": "show_vendor",
        "label": "Show Product Vendor",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "show_sku",
        "label": "Show Product SKU",
        "default": false
      },
      {
        "type": "checkbox",
        "id": "enable_product_reviews",
        "label": "Enable Product Reviews",
        "default": true
      },
      {
        "type": "select",
        "id": "product_image_zoom",
        "label": "Product Image Zoom",
        "options": [
          {
            "value": "none",
            "label": "No zoom"
          },
          {
            "value": "hover",
            "label": "Zoom on hover"
          },
          {
            "value": "click",
            "label": "Zoom on click"
          }
        ],
        "default": "hover"
      }
    ]
  }
