{% comment %}
  Product card snippet for displaying products in grids
  Usage: {% render 'product-card', product: product %}
{% endcomment %}

<div class="product-card card">
  <div class="product-image-wrapper">
    <a href="{{ product.url }}" class="product-link">
      {% if product.featured_image %}
        <img 
          src="{{ product.featured_image | img_url: '400x400' }}" 
          alt="{{ product.featured_image.alt | default: product.title }}"
          class="product-image"
          loading="lazy"
        >
        
        {% comment %} Show second image on hover if available {% endcomment %}
        {% if product.images.size > 1 %}
          <img 
            src="{{ product.images[1] | img_url: '400x400' }}" 
            alt="{{ product.images[1].alt | default: product.title }}"
            class="product-image-hover"
            loading="lazy"
          >
        {% endif %}
      {% else %}
        <div class="product-no-image">
          <span>No Image</span>
        </div>
      {% endif %}
    </a>
    
    <!-- Product badges -->
    <div class="product-badges">
      {% if product.tags contains 'new' %}
        <span class="product-badge badge-new">New</span>
      {% endif %}
      {% if product.tags contains 'bestseller' %}
        <span class="product-badge badge-bestseller">Bestseller</span>
      {% endif %}
      {% if product.compare_at_price > product.price %}
        <span class="product-badge badge-sale">
          Save {{ product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price | round }}%
        </span>
      {% endif %}
      {% unless product.available %}
        <span class="product-badge badge-sold-out">Sold Out</span>
      {% endunless %}
    </div>
    
    <!-- Quick add button -->
    {% if product.available and product.has_only_default_variant %}
      <div class="quick-add-wrapper">
        <form action="/cart/add" method="post" class="quick-add-form">
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
          <button type="submit" class="btn btn-primary btn-sm quick-add-btn" data-add-to-cart>
            Quick Add
          </button>
        </form>
      </div>
    {% endif %}
  </div>
  
  <div class="product-info card-body">
    {% if settings.show_vendor and product.vendor != blank %}
      <p class="product-vendor">{{ product.vendor }}</p>
    {% endif %}
    
    <h3 class="product-title">
      <a href="{{ product.url }}">{{ product.title }}</a>
    </h3>
    
    <!-- Product rating (placeholder for future reviews integration) -->
    {% if product.metafields.reviews.rating %}
      <div class="product-rating">
        {% assign rating = product.metafields.reviews.rating | times: 1 %}
        {% for i in (1..5) %}
          {% if i <= rating %}
            <span class="star filled">★</span>
          {% else %}
            <span class="star">☆</span>
          {% endif %}
        {% endfor %}
        <span class="rating-count">({{ product.metafields.reviews.count | default: 0 }})</span>
      </div>
    {% endif %}
    
    <!-- Price -->
    <div class="product-price-wrapper">
      {% if product.compare_at_price > product.price %}
        <span class="price-compare">{{ product.compare_at_price | money }}</span>
      {% endif %}
      <span class="product-price {% if product.compare_at_price > product.price %}price-sale{% endif %}">
        {{ product.price | money }}
      </span>
    </div>
    
    <!-- Key benefits for supplements -->
    {% if product.metafields.custom.key_benefits %}
      <div class="product-benefits">
        <ul>
          {% assign benefits = product.metafields.custom.key_benefits | split: ',' %}
          {% for benefit in benefits limit: 3 %}
            <li>{{ benefit | strip }}</li>
          {% endfor %}
        </ul>
      </div>
    {% endif %}
    
    <!-- Product description excerpt -->
    {% if product.description != blank %}
      <div class="product-excerpt">
        {{ product.description | strip_html | truncate: 100 }}
      </div>
    {% endif %}
    
    <!-- View product button -->
    <div class="product-actions">
      <a href="{{ product.url }}" class="btn btn-secondary btn-sm">
        View Details
      </a>
    </div>
  </div>
</div>

<style>
  .product-card {
    position: relative;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    height: 100%;
    display: flex;
    flex-direction: column;
  }
  
  .product-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 25px rgba(0,0,0,0.15);
  }
  
  .product-image-wrapper {
    position: relative;
    overflow: hidden;
    background: #f8f9fa;
  }
  
  .product-image,
  .product-image-hover {
    width: 100%;
    height: 250px;
    object-fit: cover;
    transition: opacity 0.3s ease;
  }
  
  .product-image-hover {
    position: absolute;
    top: 0;
    left: 0;
    opacity: 0;
  }
  
  .product-card:hover .product-image-hover {
    opacity: 1;
  }
  
  .product-no-image {
    height: 250px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f0f0f0;
    color: #999;
    font-weight: 600;
  }
  
  .product-badges {
    position: absolute;
    top: 0.5rem;
    left: 0.5rem;
    z-index: 2;
  }
  
  .product-badge {
    display: block;
    margin-bottom: 0.25rem;
  }
  
  .badge-sold-out {
    background-color: #6c757d;
    color: white;
  }
  
  .quick-add-wrapper {
    position: absolute;
    bottom: 0.5rem;
    right: 0.5rem;
    opacity: 0;
    transform: translateY(10px);
    transition: all 0.3s ease;
  }
  
  .product-card:hover .quick-add-wrapper {
    opacity: 1;
    transform: translateY(0);
  }
  
  .quick-add-form {
    margin: 0;
  }
  
  .quick-add-btn {
    font-size: 0.75rem;
    padding: 0.375rem 0.75rem;
    white-space: nowrap;
  }
  
  .product-info {
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  
  .product-vendor {
    font-size: 0.75rem;
    color: #6c757d;
    text-transform: uppercase;
    font-weight: 600;
    margin-bottom: 0.25rem;
  }
  
  .product-title {
    font-size: 1rem;
    margin-bottom: 0.5rem;
    line-height: 1.3;
  }
  
  .product-title a {
    color: var(--color-text);
    text-decoration: none;
  }
  
  .product-title a:hover {
    color: var(--color-primary);
  }
  
  .product-rating {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    margin-bottom: 0.5rem;
  }
  
  .star {
    color: #ffc107;
    font-size: 0.875rem;
  }
  
  .star:not(.filled) {
    color: #e9ecef;
  }
  
  .rating-count {
    font-size: 0.75rem;
    color: #6c757d;
  }
  
  .product-price-wrapper {
    margin-bottom: 0.75rem;
  }
  
  .product-benefits ul {
    list-style: none;
    padding: 0;
    margin: 0.5rem 0;
  }
  
  .product-benefits li {
    font-size: 0.75rem;
    color: var(--color-secondary);
    position: relative;
    padding-left: 1rem;
    margin-bottom: 0.25rem;
  }
  
  .product-benefits li:before {
    content: "✓";
    position: absolute;
    left: 0;
    color: var(--color-secondary);
    font-weight: bold;
  }
  
  .product-excerpt {
    font-size: 0.875rem;
    color: #6c757d;
    margin-bottom: 1rem;
    flex: 1;
  }
  
  .product-actions {
    margin-top: auto;
  }
  
  @media (max-width: 768px) {
    .product-image,
    .product-image-hover,
    .product-no-image {
      height: 200px;
    }
    
    .quick-add-wrapper {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>